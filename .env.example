# Bearer token required by all API endpoints except /healthz.
# Generate one: `openssl rand -hex 32`
API_TOKEN=change-me

# Host port the API listens on.
API_PORT=5000

# Ofelia cron schedule (6-field: sec min hour dom mon dow).
# Default: 7 minutes past every hour.
CRON_SCHEDULE=0 7 * * * *

# Where ytdl-sub writes downloads (host path, bind-mounted to /downloads).
DOWNLOADS_DIR=./data/downloads

# Where ofelia persists each run's stdout/stderr/status JSON. The API
# reads this dir to serve GET /runs.
OFELIA_LOGS_DIR=./data/ofelia-logs

# Path to the subscriptions YAML on the host. Defaults to the file
# in this repo; point at somewhere persistent if you prefer.
SUBSCRIPTIONS_FILE=./subscriptions.yaml

# Path to the ytdl-sub config YAML on the host (defines `configuration:`
# and any custom presets). Bind-mounted into the container at
# /config/config.yaml and passed to every run via `--config`.
CONFIG_FILE=./config.yaml

# UID/GID for the ytdl-sub container (owns files under DOWNLOADS_DIR).
PUID=1000
PGID=1000

# Timezone for cron + container logs.
TZ=UTC

# Default ytdl-sub preset used when POST /channels omits `preset`.
DEFAULT_PRESET=Jellyfin TV Show
